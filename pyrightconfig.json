{
  "typeCheckingMode": "standard",
  "reportMissingImports": true,
  "reportMissingTypeStubs": false,
  "reportUnknownMemberType": true,
  "reportUnknownVariableType": false,
  "reportUnusedExpression": true,
  "pythonVersion": "3.12",
  "venvPath": ".",
  "venv": ".venv",
  "exclude": [
    "**/__pycache__",
    "**/.venv",
    "**/venv",
    "**/build",
    "**/dist"
  ]
}
